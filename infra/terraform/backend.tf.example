# Remote state backend — OPTIONAL but strongly recommended for shared use.
#
# By default, Terraform stores state locally in terraform.tfstate.
# Local state is fine for solo experimentation, but has two risks:
#   1. If you lose the file, you lose the ability to manage or destroy the infra.
#   2. If you accidentally commit it, AWS account IDs, resource ARNs, and
#      sensitive outputs end up in git history.
#
# To use remote state:
#   1. Create an S3 bucket and DynamoDB table for locking (see below).
#   2. Copy this file to backend.tf and fill in the values.
#   3. Run `terraform init` — Terraform will migrate local state to S3.
#
# Create the S3 bucket (versioning + encryption recommended):
#   aws s3api create-bucket \
#     --bucket <YOUR_STATE_BUCKET> \
#     --region <YOUR_REGION> \
#     --create-bucket-configuration LocationConstraint=<YOUR_REGION>
#   aws s3api put-bucket-versioning \
#     --bucket <YOUR_STATE_BUCKET> \
#     --versioning-configuration Status=Enabled
#
# Create the DynamoDB table for state locking:
#   aws dynamodb create-table \
#     --table-name <YOUR_LOCK_TABLE> \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST \
#     --region <YOUR_REGION>

terraform {
  backend "s3" {
    bucket         = "<YOUR_STATE_BUCKET>"   # e.g. "my-org-terraform-state"
    key            = "k6-fargate/terraform.tfstate"
    region         = "<YOUR_REGION>"         # e.g. "eu-west-1"
    dynamodb_table = "<YOUR_LOCK_TABLE>"     # e.g. "terraform-state-lock"
    encrypt        = true
  }
}
